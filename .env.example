# GA4GH-RegBot Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it's in .gitignore

# ============================================
# LLM Configuration
# ============================================

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here-do-not-share

# OpenAI Model - which model to use
OPENAI_MODEL=gpt-3.5-turbo
# Other options: gpt-4, gpt-4-turbo-preview

# ============================================
# Document Processing
# ============================================

# Path to GA4GH policy documents
DOCUMENTS_PATH=./data/frameworks/

# Chunk size for document splitting (characters)
CHUNK_SIZE=1000

# Chunk overlap (characters)
CHUNK_OVERLAP=100

# ============================================
# Vector Store Configuration
# ============================================

# ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db/

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# Application Settings
# ============================================

# Streamlit app port (default: 8501)
STREAMLIT_PORT=8501

# Debug mode (true/false)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Optional: Advanced Settings
# ============================================

# Similarity threshold for retrieval (0.0-1.0)
SIMILARITY_THRESHOLD=0.7

# Top-K results to retrieve
TOP_K_RESULTS=5

# Maximum tokens in LLM response
MAX_TOKENS=500

# Temperature (0.0-1.0, higher = more creative)
TEMPERATURE=0.7
